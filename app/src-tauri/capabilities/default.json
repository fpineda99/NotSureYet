{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main", "tray-panel"],
  "permissions": [
    "core:default",
    "opener:default",
    "opener:allow-open-path",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        { "path": "$HOME/AudioCapture/**" }
      ]
    },
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-dir",
    "fs:allow-exists",
    "fs:allow-create",
    "fs:allow-mkdir",
    "fs:allow-rename",
    "fs:allow-stat",
    "fs:allow-remove",
    "fs:allow-watch",
    "fs:allow-unwatch",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/AudioCapture" },
        { "path": "$HOME/AudioCapture/**" },
        { "path": "$HOME/AudioCapture/*/.*" },
        { "path": "$HOME/.notate" },
        { "path": "$HOME/.notate/**" },
        { "path": "$HOME/.claude/projects" },
        { "path": "$HOME/.claude/projects/**" }
      ]
    },
    "shell:default",
    "pty:default",
    "pty:allow-spawn"
  ]
}
